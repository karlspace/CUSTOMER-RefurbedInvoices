STACK_NAME=refurbed-invoices

SHOP=your-store.myshopify.com
SHOPIFY_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REFURBED_TOKEN=your-refurbed-api-token

IMAP_SERVER={mail.example.com:993/imap/ssl}INBOX
IMAP_USERNAME=invoices@example.com
IMAP_PASSWORD=your-imap-password

# Scheduler interval in seconds. Default 3600 (hourly).
# Set to 60 temporarily for execution verification (per Magedia 2026-04-27).
# Minimum enforced by the scheduler: 30 seconds.
SCHEDULE_INTERVAL_SECONDS=3600
